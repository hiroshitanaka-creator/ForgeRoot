+#!forge/v1
+forge_version: 1
+schema_ref: urn:forgeroot:forge:policy:v1
+kind: policy
+id: forge://hiroshitanaka-creator/ForgeRoot/policy/security-gates
+revision: 01KPF0T0417G5Y6B8C9D0E1F2B
+mind_ref: forge://hiroshitanaka-creator/ForgeRoot/mind/root
+status: active
+title: ForgeRoot Security Gates Policy
+summary: Defines the T041 manifest-only security gate thresholds that convert SARIF-like findings into pass, hold, block, or quarantine decisions before PR transport authorization.
+owners:
+  - github://hiroshitanaka-creator
+  - github-app://forgeroot
+created_at: 2026-04-18T00:00:00Z
+updated_at: 2026-04-19T00:00:00Z
+policy_type: security-gates
+rules:
+  - id: sarif-high-blocks-transport
+    statement: A high severity SARIF-like finding blocks transport authorization unless a stricter quarantine rule applies.
+    pass_conditions:
+      sarif_forge_severity: high
+      gate_decision:
+        - block
+        - quarantine
+      approval_checkpoint_status:
+        - block_transport_authorization
+        - quarantine_candidate
+    fail_conditions:
+      high_finding_passed: true
+      high_finding_held_without_reason: true
+    required_approval_class: C
+  - id: critical-source-quarantines-candidate
+    statement: A critical-equivalent source severity finding quarantines the candidate before PR transport.
+    pass_conditions:
+      source_severity:
+        - critical
+        - fatal
+        - security_critical
+      gate_decision: quarantine
+    fail_conditions:
+      critical_source_passed: true
+      critical_source_blocked_without_quarantine: true
+    required_approval_class: C
+  - id: medium-defaults-to-hold
+    statement: Medium severity findings are held for human review by default.
+    pass_conditions:
+      sarif_forge_severity: medium
+      default_gate_decision: hold
+    fail_conditions:
+      medium_finding_passed_without_policy_override: true
+    required_approval_class: B
+  - id: low-docs-tests-can-pass
+    statement: Low or note severity findings in docs or tests may pass when no denied rule, critical source severity, runtime stop, rate stop, or immutable path violation is present.
+    pass_conditions:
+      sarif_forge_severity:
+        - low
+        - note
+      allowed_path_classes:
+        - docs
+        - tests
+      gate_decision: pass
+    fail_conditions:
+      low_docs_tests_quarantined_without_reason: true
+    required_approval_class: B
+  - id: denied-rule-quarantines
+    statement: A denied ruleId is treated as an immune signal and quarantines the candidate.
+    pass_conditions:
+      denied_rule_id_present: true
+      gate_decision: quarantine
+    fail_conditions:
+      denied_rule_id_passed: true
+      denied_rule_id_held_only: true
+    required_approval_class: C
+  - id: immutable-path-quarantines
+    statement: A finding on an immutable governance surface quarantines the candidate before transport.
+    match_paths:
+      - .github/workflows/**
+      - .github/actions/**
+      - .forge/mind.forge
+      - .forge/policies/**
+      - .forge/network/**
+      - apps/github-app/app-manifest.json
+    pass_conditions:
+      immutable_path_violation_present: true
+      gate_decision: quarantine
+    fail_conditions:
+      immutable_path_passed: true
+      immutable_path_blocked_without_quarantine: true
+    required_approval_class: C
+  - id: runtime-stop-quarantines
+    statement: Runtime mode quarantine or halted, or an engaged kill switch, quarantines the candidate before trusted transport.
+    pass_conditions:
+      runtime_modes:
+        - quarantine
+        - halted
+      kill_switch_engaged: true
+      gate_decision: quarantine
+    fail_conditions:
+      runtime_stop_ignored: true
+    required_approval_class: C
+  - id: no-live-github-mutation
+    statement: The T041 security gate emits only a deterministic decision manifest and never uploads SARIF, mutates rulesets, changes branch protection, creates PRs, approves, merges, or calls GitHub APIs.
+    pass_conditions:
+      live_code_scanning_upload: false
+      github_api_call: false
+      ruleset_mutation: false
+      branch_protection_mutation: false
+      pull_request_creation: false
+    fail_conditions:
+      live_code_scanning_upload: true
+      github_api_call: true
+      ruleset_mutation: true
+      branch_protection_mutation: true
+      pull_request_creation: true
+    required_approval_class: C
+thresholds:
+  severity_actions:
+    high: block
+    medium: hold
+    low: pass
+    note: pass
+  critical_source_severities:
+    - critical
+    - fatal
+    - security_critical
+  denied_rule_ids:
+    - forge.secret_scanning
+    - forge.secret-scanning
+    - forge.permission_drift
+    - forge.permission-drift
+    - forge.workflow_class_mismatch
+    - forge.workflow-class-mismatch
+    - forge.default_branch_write
+    - forge.default-branch-write
+    - security.secret
+    - security.secret-scanning
+    - security.credential-leak
+  allowed_rule_ids: []
+  immutable_path_patterns:
+    - .github/workflows/**
+    - .github/actions/**
+    - .forge/mind.forge
+    - .forge/policies/**
+    - .forge/network/**
+    - apps/github-app/app-manifest.json
+  low_risk_path_patterns:
+    - docs/**
+    - '**/*.md'
+    - '**/*.mdx'
+    - tests/**
+    - '**/tests/**'
+    - '**/*.test.mjs'
+    - '**/*.test.js'
+    - '**/*.test.ts'
+  path_actions:
+    immutable: quarantine
+  rule_actions:
+    denied: quarantine
+    not_allowed: block
+  boundary_actions:
+    runtime_halted_or_quarantined: quarantine
+    runtime_not_mutating_when_enforced: hold
+    rate_blocked: block
+    rate_delayed_or_cooldown: hold
+actions_on_breach:
+  sarif-high-blocks-transport:
+    - block_transport_authorization
+    - require_human_security_review
+  critical-source-quarantines-candidate:
+    - quarantine_candidate
+    - open_incident_review
+  medium-defaults-to-hold:
+    - hold_for_human_review
+  denied-rule-quarantines:
+    - quarantine_candidate
+    - require_policy_owner_review
+  immutable-path-quarantines:
+    - quarantine_candidate
+    - require_codeowner_review
+  runtime-stop-quarantines:
+    - quarantine_candidate
+    - keep_runtime_mode
+  no-live-github-mutation:
+    - reject_gate_runtime
+    - keep_manifest_only
+required_approvals:
+  A:
+    summary: docs, tests, comments, and low-risk refactors
+    min_human_approvals: 0
+    auto_pr_allowed: true
+    merge_requires_human: false
+  B:
+    summary: normal code changes and held medium findings
+    min_human_approvals: 1
+    auto_pr_allowed: true
+    merge_requires_human: true
+  C:
+    summary: security gate block, quarantine, policy, workflow, or governance surface findings
+    min_human_approvals: 2
+    auto_pr_allowed: false
+    codeowner_required: true
+  D:
+    summary: branch protection, GitHub App permission, ruleset, open federation, and workflow mutation
+    min_human_approvals: 2
+    auto_pr_allowed: false
+    codeowner_required: true
+    self_approval_forbidden: true
+    human_only_operation: true
+cooldowns:
+  quarantine_restore:
+    automatic_restore: forbidden
+    requires_human_ack: true
+  held_medium_review:
+    max_staleness: P7D
+quarantine_triggers:
+  - sarif_high_or_critical
+  - denied_rule_id
+  - immutable_path_violation
+  - runtime_halted
+  - kill_switch_engaged
+  - secret_scanning_signal
+provenance:
+  seed_task: T041
+  seed_basis:
+    - 00_ForgeRoot_blueprint_設計書.md
+    - 03_issue.md 追補案：T040以降 canonical task source
+    - T040 SARIF bridge
+  created_by: github://hiroshitanaka-creator
+  implemented_by: github-app://forgeroot
+extensions: {}
