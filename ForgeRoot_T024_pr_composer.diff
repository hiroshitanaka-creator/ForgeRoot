+function buildComposition(plan: JsonRecord, worktreePlan: JsonRecord, sandboxRequest: JsonRecord, sandboxOutput: JsonRecord, audit: JsonRecord, input: PullRequestComposerInput, createdAt: string): PullRequestComposition {
