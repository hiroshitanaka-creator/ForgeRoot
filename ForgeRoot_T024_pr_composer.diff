+  const approvalClass = stringValue(risk["approval_class"]) ?? stringValue(asRecord(audit["risk_summary"])?.["approval_class"]) ?? "B";
+  const riskLevel = stringValue(risk["risk"]) ?? stringValue(asRecord(audit["risk_summary"])?.["risk"]) ?? "medium";
