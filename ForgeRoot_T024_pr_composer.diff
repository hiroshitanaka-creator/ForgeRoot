+    status: "ready",
+    composition,
+    reasons: uniqueStrings([
+      "pull_request_composition_ready",
+      `composition:${composition.composition_id}`,
+      `head:${composition.pull_request.head}`,
+      `base:${composition.pull_request.base}`,
+      `audit:${composition.audit_id}`,
