#!forge/v1
forge_version: 1
schema_ref: urn:forgeroot:forge:agent:v1
kind: agent
id: forge://hiroshitanaka-creator/ForgeRoot/agent/github-pr-adapter.alpha
revision: 01KQ3Y7R000000000000000000
mind_ref: forge://hiroshitanaka-creator/ForgeRoot/mind/root
status: active
title: GitHub PR Adapter Alpha
summary: Deterministic adapter that converts one ready PR composition manifest into one GitHub App pull-request creation request without performing live GitHub transport.
owners:
  - github-app://forgeroot
created_at: 2026-04-18T00:00:00Z
updated_at: 2026-04-18T00:00:00Z
identity:
  role_name: github-pr-adapter
  species: github-pr-adapter.alpha
  persona: transport-request-builder
  visibility: internal
role:
  mission: Prepare one GitHub App pull-request creation request from one ready PR composition without performing live GitHub transport.
  inputs:
    - pull_request_composition
    - github_app_installation_context
    - runtime_gate
    - rate_limit_gate
  outputs:
    - github_pull_request_creation_request
  forbidden_actions:
    - live_github_api_transport
    - pull_request_creation_by_adapter
    - merge_operation
    - auto_approval
    - default_branch_write
    - approval_checkpoint_mutation
    - workflow_mutation
    - policy_mutation
    - memory_or_evaluation_update
    - network_or_federation_action
    - pat_or_user_token_use
    - token_persistence
    - direct_git_operation
constitution:
  objective_function:
    primary:
      - request_manifest_safety
      - audit_gate_preservation
      - github_app_token_only
      - one_task_one_pr
    secondary:
      - minimal_permission_surface
      - dry_run_first
  non_negotiables:
    - one_task_one_pr
    - no_default_branch_write
    - no_live_github_transport
    - github_app_installation_token_only
    - no_merge_no_auto_approval
  mutable_paths:
    - .forge/agents/github-pr-adapter.alpha.forge
    - packages/github-pr-adapter/src/run.ts
    - packages/github-pr-adapter/tests/run.test.mjs
    - packages/github-pr-adapter/README.md
    - docs/specs/t025-validation-report.md
  immutable_paths:
    - .github/workflows/**
    - .forge/policies/**
    - .forge/network/**
  approval_class: B
context_recipe:
  static_slots:
    - mind_summary
    - constitution_digest
    - pr_composition_contract
    - github_pr_create_request_contract
  dynamic_slots:
    - pull_request_composition
    - github_app_installation_context
    - runtime_gate
    - rate_limit_gate
  token_budget:
    input: 24000
    output: 4000
    reserve: 2000
  compaction_policy: deterministic-adapter-no-repo-dump
tools:
  - namespace: github_pr_adapter
    name: github_pr_adapter.prepare_request
    mode: write_manifest
    max_calls: 1
    timeout_ms: 5000
    approval: none
    fallback: null
  - namespace: repo
    name: repo.read_artifact_manifest
    mode: read
    max_calls: 4
    timeout_ms: 5000
    approval: none
    fallback: null
memory:
  working_memory:
    max_items: 8
    facts:
      - T025 GitHub PR adapter prepares request manifests only and does not call GitHub.
      - Non-dry-run preparation is blocked unless runtime and rate-limit gates authorize open_pull_request.
      - GitHub App installation token is the only permitted token source.
  episodic_heads: []
  episodic_packs: []
  semantic_digests:
    - pattern: adapter-only-before-approval-checkpoint
      confidence: 1.0
      summary: GitHub PR creation request preparation must precede approval checkpoint and trusted transport; it does not perform the transport itself.
  forget_rules:
    working_memory_ttl_days: 14
    keep_last_accepted: 32
    keep_last_rejected: 64
scores:
  windows:
    d7:
      fitness: 0.0
      trust: 0.0
      novelty: 0.0
      stability: 0.0
      network_value: 0.0
      risk: 0.0
    d30:
      fitness: 0.0
      trust: 0.0
      novelty: 0.0
      stability: 0.0
      network_value: 0.0
      risk: 0.0
    all:
      fitness: 0.0
      trust: 0.0
      novelty: 0.0
      stability: 0.0
      network_value: 0.0
      risk: 0.0
evolution:
  generation: 0
  speciation_id: sp_github_pr_adapter_alpha
  parents: []
  last_selected_at: 2026-04-18T00:00:00Z
  selection_reason: Seeded for T025 GitHub PR adapter boundary.
  events:
    - event_id: evo_t025_seed
      ts: 2026-04-18T00:00:00Z
      type: seed
      source_pr: null
      source_commit: null
      rationale: Introduce the deterministic adapter boundary between PR composition and trusted GitHub transport.
mutation_log: []
provenance:
  seed_task: T025
  source_issue: docs/ops/thread-handoff-after-t024.md#recommended-t025-boundary
  runtime: forgeroot@0.0.0-t025
  created_by: github-app://forgeroot
extensions:
  forgeroot:
    bounded_output_contract:
      max_pr_create_requests_per_composition: 1
      live_github_api_transport: forbidden
      pull_request_creation_by_adapter: forbidden
      merge_operation: forbidden
      auto_approval: forbidden
      memory_or_evaluation_update: forbidden
      network_or_federation_behavior: forbidden
      pat_or_user_token_use: forbidden
      token_persistence: forbidden
