+      .map((criterion) => ({ id: criterion.check.command.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "").slice(0, 64), command: criterion.check.command, exit_code: criterion.check.expected_exit_code ?? 0, outcome: "passed" })),
