+    assert.ok(git.reasons.includes("forbidden_command_binary:git"));
+
+    const shell = createSandboxExecutionRequest(worktree, {
+      now: CREATED_AT,
+      commands: [{ id: "shell", phase: "execute", argv: ["bash", "-c", "echo unsafe"], writable_paths: [] }],
