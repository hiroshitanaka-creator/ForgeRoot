 cd packages/planner
-TSC_NONPOLLING_WATCHER=1 tsc -p tsconfig.json --noEmit --pretty false --diagnostics
+timeout 20 tsc -p tsconfig.json
 node --test --test-force-exit tests/*.test.mjs
 ```
