+test("T040 contract remains manifest-only and forbids live GitHub/security-surface mutation", () => {
+  assert.equal(SARIF_BRIDGE_CONTRACT.manifestOnly, true);
+  assert.equal(SARIF_BRIDGE_CONTRACT.deterministic, true);
